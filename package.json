{
  "name": "senior-vibe-agent",
  "displayName": "Senior Vibe Agent",
  "description": "AI-powered code review for Vibe Coding projects",
  "version": "0.1.0",
  "publisher": "senior-vibe",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "code review",
    "vibe coding",
    "ai",
    "linter",
    "quality"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onCommand:seniorVibe.reviewWorkspace",
    "onCommand:seniorVibe.reviewFile",
    "onCommand:seniorVibe.showPanel",
    "onCommand:seniorVibe.clearDiagnostics",
    "onCommand:seniorVibe.viewHistory",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onLanguage:java",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:cpp",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "seniorVibe.reviewWorkspace",
        "title": "Senior Vibe: Review Workspace"
      },
      {
        "command": "seniorVibe.reviewFile",
        "title": "Senior Vibe: Review Current File"
      },
      {
        "command": "seniorVibe.reviewOnSave",
        "title": "Senior Vibe: Toggle Review on Save"
      },
      {
        "command": "seniorVibe.showPanel",
        "title": "Senior Vibe: Show Results"
      },
      {
        "command": "seniorVibe.clearDiagnostics",
        "title": "Senior Vibe: Clear Diagnostics"
      },
      {
        "command": "seniorVibe.viewHistory",
        "title": "Senior Vibe: View History"
      }
    ],
    "keybindings": [
      {
        "command": "seniorVibe.reviewWorkspace",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "seniorVibe",
          "title": "Senior Vibe Agent",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "seniorVibe": [
        {
          "type": "tree",
          "id": "seniorVibe.results",
          "name": "Review Results"
        }
      ]
    },
    "configuration": {
      "title": "Senior Vibe Agent",
      "properties": {
        "seniorVibe.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter used to run the review engine"
        },
        "seniorVibe.reviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run review on file save"
        },
        "seniorVibe.minSeverity": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "info"
          ],
          "default": "info",
          "description": "Minimum severity level to show in diagnostics"
        },
        "seniorVibe.showPanelOnReview": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the results panel after a review"
        },
        "seniorVibe.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns to exclude from review"
        },
        "seniorVibe.enableAiFixes": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI-powered fix suggestions (requires API key)"
        },
        "seniorVibe.llmProvider": {
          "type": "string",
          "enum": [
            "auto",
            "anthropic",
            "openai"
          ],
          "default": "auto",
          "description": "LLM provider for AI fix suggestions"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild",
    "esbuild": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --minify",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.19.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.3.0"
  }
}
